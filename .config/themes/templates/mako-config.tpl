font=JetBrainsMono Nerd Font {{FONT_SIZE}}
background-color={{BG}}
text-color={{FG}}
outer-margin=8
padding=12
width=500
height=300
border-size=2
border-color={{ACCENT}}
border-radius=12
progress-color=source {{ACCENT}}
icon-path=/usr/share/icons/Papirus-Dark
default-timeout=10000
max-visible=3

[urgency=low]
border-color={{DIM}}

[urgency=critical]
border-color={{COLOR_RED}}

[mode=dnd]
invisible=1
